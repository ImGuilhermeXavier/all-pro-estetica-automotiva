---
import "@fontsource-variable/manrope";
import "@fontsource/rajdhani/500.css";
import "@fontsource/rajdhani/600.css";
import "@fontsource/rajdhani/700.css";
import "@styles/tokens.css";

import Header from "@components/layout/Header.astro";
import Footer from "@components/layout/Footer.astro";
import WhatsAppFloat from "@components/layout/WhatsAppFloat.astro";
import { getBusinessJsonLd, getFaqJsonLd } from "@lib/seo";
import { business } from "@content/business";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  keywords?: string;
}

const {
  title = `${business.name} | PPF, Vitrificação, Insulfilm e Polimento em Campinas - SP`,
  description = `Estética automotiva premium em Campinas. PPF, vitrificação cerâmica, polimento técnico, insulfilm, envelopamento, funilaria e martelinho de ouro — materiais premium e mão de obra especializada.`,
  ogImage = "/og-image.jpg",
  keywords = "estética automotiva Campinas, PPF Campinas, vitrificação cerâmica Campinas, polimento automotivo Campinas, insulfilm Campinas, envelopamento automotivo Campinas, martelinho de ouro Campinas, funilaria Campinas, higienização interna carro Campinas, proteção de pintura carro SP",
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "https://allproesteticaautomotiva.com.br";
const canonical = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();

const businessJsonLd = getBusinessJsonLd(siteUrl);
const faqJsonLd = getFaqJsonLd();
const ga4Id = import.meta.env.PUBLIC_GA4_ID;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO fundamental -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={business.name} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <link rel="canonical" href={canonical} />

    <!-- Favicons e manifest PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Preconnect para Google Maps (iframe na seção de localização) -->
    <link rel="preconnect" href="https://maps.googleapis.com" />
    <link rel="preconnect" href="https://maps.gstatic.com" crossorigin />

    <!-- Open Graph / WhatsApp / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content={business.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${business.name} — estética automotiva premium em Campinas SP`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={`${business.name} — estética automotiva premium em Campinas SP`} />

    <!-- Geo tags para SEO local -->
    <meta name="geo.region" content="BR-SP" />
    <meta name="geo.placename" content="Campinas, São Paulo, Brasil" />
    <meta name="geo.position" content="-22.848;-47.0576" />
    <meta name="ICBM" content="-22.848, -47.0576" />

    <!-- JSON-LD: AutomotiveBusiness + LocalBusiness -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(businessJsonLd)}
    />

    <!-- JSON-LD: FAQ (rich results no Google) -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(faqJsonLd)}
    />

    <!-- GA4 via Partytown (rodando em web worker, sem impactar INP) -->
    {
      ga4Id && (
        <>
          <script
            is:inline
            type="text/partytown"
            src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`}
            async
          />
          <script
            is:inline
            type="text/partytown"
            set:html={`
              window.dataLayer = window.dataLayer || [];
              function gtag(){dataLayer.push(arguments);}
              gtag('js', new Date());
              gtag('config', '${ga4Id}', { anonymize_ip: true });
            `}
          />
        </>
      )
    }
  </head>
  <body>
    <a href="#main" class="skip-link">Pular para o conteúdo principal</a>

    <Header />

    <main id="main">
      <slot />
    </main>

    <Footer />
    <WhatsAppFloat />

    <!-- Scroll-reveal sutil (Intersection Observer leve) -->
    <script>
      const reveal = () => {
        const els = document.querySelectorAll<HTMLElement>(".reveal");
        if (!("IntersectionObserver" in window) || els.length === 0) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const obs = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.15 },
        );
        els.forEach((el) => obs.observe(el));
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", reveal);
      } else {
        reveal();
      }
    </script>
  </body>
</html>
