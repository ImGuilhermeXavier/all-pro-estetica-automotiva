---
import { Icon } from "astro-icon/components";
import { getWhatsAppLink } from "@lib/whatsapp";

const href = getWhatsAppLink();
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Falar no WhatsApp com a ALL PRO Estética Automotiva"
  data-origin="floating"
  class="fixed bottom-4 right-4 z-[600] inline-flex h-14 w-14 items-center justify-center rounded-full bg-[var(--color-whatsapp)] text-[var(--color-neutral-900)] shadow-[var(--shadow-whatsapp)] transition-all duration-200 ease-[var(--ease-out-soft)] hover:scale-105 hover:bg-[var(--color-whatsapp-hover)] focus-visible:outline-2 focus-visible:outline-offset-3 focus-visible:outline-[var(--color-brand)] motion-safe:animate-pulse-soft md:bottom-8 md:right-8 md:h-16 md:w-16"
>
  <Icon name="lucide:message-circle" width={28} height={28} aria-hidden="true" />
</a>
