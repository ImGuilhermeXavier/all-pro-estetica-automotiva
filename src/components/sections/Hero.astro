---
import { Image } from "astro:assets";
import carro from "@assets/carro.webp";
import Button from "@components/ui/Button.astro";
import { getWhatsAppLink } from "@lib/whatsapp";
import { business } from "@content/business";

const waLink = getWhatsAppLink();
---

<section class="relative overflow-hidden bg-[var(--color-neutral-900)]">
  <div class="absolute inset-0 -z-10">
    <Image
      src={carro}
      alt="Toyota Corolla Cross prateado polido em frente à fachada da ALL PRO Estética Automotiva"
      class="h-full w-full object-cover object-center"
      widths={[480, 768, 1024, 1440, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      quality={85}
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-[var(--color-neutral-900)]/60 via-[var(--color-neutral-900)]/65 to-[var(--color-neutral-900)]/95"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-0 bg-gradient-to-r from-[var(--color-neutral-900)]/70 via-transparent to-transparent"
      aria-hidden="true"
    >
    </div>
  </div>

  <div
    class="container-base relative flex min-h-[88vh] flex-col items-start justify-center py-20 md:min-h-[92vh] md:py-32"
  >
    <div class="max-w-3xl">
      <p
        class="text-overline mb-5 text-[var(--color-brand)]"
      >
        Estética automotiva premium · Campinas - SP
      </p>

      <h1 class="text-display mb-6 uppercase text-[var(--color-neutral-0)]">
        {business.taglinePrimary}
      </h1>

      <p
        class="mb-10 max-w-2xl text-lg leading-relaxed text-[var(--color-neutral-100)] md:text-xl"
      >
        {business.taglineSecondary}. PPF, vitrificação, polimento, insulfilm e muito mais — com mão
        de obra especializada e materiais premium.
      </p>

      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:gap-4">
        <Button
          href={waLink}
          variant="primary"
          size="lg"
          icon="lucide:message-circle"
          external
          ariaLabel="Solicitar orçamento no WhatsApp"
          dataOrigin="hero_primary"
        >
          Solicitar orçamento
        </Button>

        <Button
          href="#servicos"
          variant="ghost"
          size="lg"
          iconRight="lucide:arrow-right"
          dataOrigin="hero_secondary"
        >
          Ver serviços
        </Button>
      </div>
    </div>
  </div>
</section>
