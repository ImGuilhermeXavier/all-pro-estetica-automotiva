---

const reviews = [
  {
    name: "Rayssa Souza",
    text: "Trabalho de altíssima qualidade. PPF e insulfilm aplicados com perfeição, atenção aos detalhes e ótimo atendimento.",
    date: "2 meses atrás",
  },
  {
    name: "Marisa Cardoso de Souza",
    text: "Qualidade, competência e preço justo! Tudo em um lugar só. Super indico!!!",
    date: "2 meses atrás",
  },
  {
    name: "Rafael Gavioli",
    text: "Serviço de qualidade, cumprem o que prometem. Levei meu Nivus para aplicar PPF e Insulfilm — um dos melhores serviços feito no meu carro.",
    date: "2 meses atrás",
  },
  {
    name: "Jose Matias Filho",
    text: "Excelente serviço. Muito cuidado aos detalhes e ao prazo de entrega.",
    date: "1 mês atrás",
  },
  {
    name: "Gabriel Candido",
    text: "Super indico — excelente profissional e um trabalho de qualidade.",
    date: "2 meses atrás",
  },
  {
    name: "Rociane Mendes",
    text: "Excelente atendimento. Saí muito satisfeita com o resultado. Recomendo!",
    date: "2 meses atrás",
  },
];

const GOOGLE_REVIEWS_URL =
  "https://www.google.com/search?q=ALL+PRO+estetica+automotiva+Campinas#lrd=0x94c8c9ceff4877cf:0x570670c2ad5e4bcc,1,,,,";
---

<section class="bg-[var(--color-neutral-900)] py-20 md:py-24">
  <div class="container-base">
    <!-- Cabeçalho -->
    <div class="reveal mx-auto max-w-2xl text-center">
      <p class="text-overline mb-4 text-[var(--color-brand)]">Avaliações Google</p>
      <h2 class="text-h2 mb-4 text-[var(--color-neutral-0)]">
        O que dizem nossos clientes
      </h2>

      <!-- Rating geral -->
      <div class="mt-6 inline-flex items-center gap-3 rounded-[var(--radius-lg)] border border-[var(--color-neutral-700)] bg-[var(--color-neutral-800)] px-5 py-3">
        <span class="font-display text-3xl font-bold text-[var(--color-neutral-0)]">5,0</span>
        <div class="flex items-center gap-0.5" aria-label="5 de 5 estrelas">
          {Array.from({ length: 5 }).map(() => (
            <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-brand)" aria-hidden="true">
              <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" />
            </svg>
          ))}
        </div>
        <span class="text-sm text-[var(--color-neutral-300)]">· 41 avaliações</span>
      </div>
    </div>

    <!-- Grade de cards -->
    <div class="reveal mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        reviews.map((review) => (
          <article class="flex flex-col gap-4 rounded-[var(--radius-lg)] border border-[var(--color-neutral-700)] bg-[var(--color-neutral-800)] p-6 transition-colors duration-200 hover:border-[var(--color-neutral-600)]">
            <!-- Aspas decorativas -->
            <svg
              class="h-7 w-7 shrink-0 text-[var(--color-brand)]"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path d="M11.192 15.757c0-.88-.23-1.618-.69-2.217-.326-.412-.768-.683-1.327-.812-.55-.128-1.07-.137-1.54-.028-.16-.95.1-1.956.76-3.022.66-1.065 1.515-1.867 2.558-2.403L9.373 5c-.8.396-1.56.898-2.26 1.505-.71.607-1.34 1.305-1.9 2.094s-.98 1.68-1.25 2.69-.346 2.04-.217 3.1c.168 1.4.62 2.52 1.356 3.35.735.84 1.652 1.26 2.748 1.26.965 0 1.766-.29 2.4-.878.628-.576.94-1.365.94-2.368l.002-.004zm9.124 0c0-.88-.23-1.618-.69-2.217-.326-.42-.77-.692-1.327-.817-.56-.124-1.074-.13-1.54-.022-.16-.94.09-1.95.75-3.02.66-1.06 1.514-1.86 2.557-2.4L18.49 5c-.8.396-1.555.898-2.26 1.505-.708.607-1.34 1.305-1.894 2.094-.556.79-.97 1.68-1.24 2.69-.273 1-.345 2.04-.217 3.1.168 1.4.62 2.52 1.356 3.35.735.84 1.652 1.26 2.748 1.26.965 0 1.766-.29 2.4-.878.628-.576.94-1.365.94-2.368l.002-.004z" />
            </svg>

            <!-- Texto do review -->
            <p class="flex-1 text-sm leading-relaxed text-[var(--color-neutral-200)]">
              {review.text}
            </p>

            <!-- Rodapé: nome + estrelas -->
            <footer class="mt-2 flex items-center justify-between gap-3 border-t border-[var(--color-neutral-700)] pt-4">
              <div>
                <p class="text-sm font-semibold text-[var(--color-neutral-0)]">{review.name}</p>
                <p class="mt-0.5 text-xs text-[var(--color-neutral-400)]">{review.date}</p>
              </div>
              <div class="flex items-center gap-0.5 shrink-0" aria-label="5 estrelas">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--color-brand)" aria-hidden="true">
                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26" />
                  </svg>
                ))}
              </div>
            </footer>
          </article>
        ))
      }
    </div>

    <!-- CTA para ver todas as avaliações -->
    <div class="reveal mt-10 text-center">
      <a
        href={GOOGLE_REVIEWS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-[var(--radius-md)] border border-[var(--color-neutral-700)] bg-[var(--color-neutral-800)] px-6 py-3 text-sm font-semibold text-[var(--color-neutral-100)] transition-all duration-200 hover:border-[var(--color-neutral-500)] hover:text-[var(--color-neutral-0)] focus-visible:outline-2 focus-visible:outline-[var(--color-brand)]"
      >
        Ver todas as avaliações no Google
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
        </svg>
      </a>
    </div>
  </div>
</section>
